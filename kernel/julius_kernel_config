# Julius OS Kernel Configuration
# Enables all drivers needed for our backend services

# Core
CONFIG_EXPERT=y
CONFIG_EMBEDDED=y
CONFIG_KERNEL_GZIP=y

# Process Management
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_MEMCG=y
CONFIG_CGROUP_DEVICE=y

# Security
CONFIG_SECURITY=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_SECURITY_SELINUX=y
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y

# IPC
CONFIG_UNIX=y
CONFIG_UNIX_DIAG=y
CONFIG_INET=y
CONFIG_INET_DIAG=y
CONFIG_PACKET=y
CONFIG_NET_UNIX=y

# Filesystem
CONFIG_EXT4_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_INOTIFY_USER=y
CONFIG_FANOTIFY=y

# Display
CONFIG_FB=y
CONFIG_FB_SSD1306=y
CONFIG_FB_ST7789V=y
CONFIG_FB_SIMPLE=y
CONFIG_DRM=y
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_PWM=y

# Input
CONFIG_INPUT=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_TOUCHSCREEN_GOODIX=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_GPIO_KEYS=y

# GPIO
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
CONFIG_GPIO_CDEV=y

# SPI
CONFIG_SPI=y
CONFIG_SPI_MASTER=y
CONFIG_SPI_GPIO=y
CONFIG_SPI_SPIDEV=y

# I2C
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_GPIO=y

# WiFi
CONFIG_WLAN=y
CONFIG_MAC80211=y
CONFIG_CFG80211=y
CONFIG_RTL8723DS=y

# Bluetooth
CONFIG_BT=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_RTL=y

# USB
CONFIG_USB=y
CONFIG_USB_GADGET=y
CONFIG_USB_ETH=y
CONFIG_USB_MASS_STORAGE=y

# Power
CONFIG_POWER_SUPPLY=y
CONFIG_BATTERY_BQ27XXX=y
CONFIG_CHARGER_BQ25890=y
CONFIG_REGULATOR=y
CONFIG_REGULATOR_AXP20X=y
CONFIG_MFD_AXP20X=y

# Thermal
CONFIG_THERMAL=y
CONFIG_CPU_THERMAL=y

# Crypto
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_HMAC=y
CONFIG_CRYPTO_RNG=y
CONFIG_HW_RANDOM=y
